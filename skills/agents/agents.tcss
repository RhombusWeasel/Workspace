AgentPanel {
    height: 100%;
    background: $surface;
}

AgentPanel .agent-panel-header {
    height: 3;
    padding: 0 1;
    background: $surface;
    align: center middle;
}

AgentPanel .agent-panel-title {
    text-style: bold;
    color: $text;
    width: 1fr;
}

AgentPanel .agent-new-btn {
    min-width: 3;
    height: 1;
    border: none;
}
Sidebar {
    width: 1fr;
    height: 1fr;
    overflow-y: auto;
    border: round $surface-lighten-1;
}

Sidebar TabbedContent {
    width: 1fr;
    height: 1fr;
}

Sidebar TabbedContent TabPane {
    width: 1fr;
    height: 1fr;
}

Sidebar TabbedContent > ContentSwitcher {
    width: 1fr;
    height: 1fr;
}

SidebarContainer {
    width: 20%;
    height: 1fr;
    overflow: hidden;
}

SidebarContainer.hidden {
    width: 0;
}

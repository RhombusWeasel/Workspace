TreeRow {
    width: 1fr;
    height: 1;
    min-height: 1;
    max-height: 1;
}

TreeRow:hover {
    text-style: bold;
}

ActionRow {
    width: 1fr;
    height: 1;
    min-height: 1;
    max-height: 1;
}

ActionRow > Horizontal {
    width: 1fr;
    height: 1;
}

ActionRow Static {
    width: 1fr;
}

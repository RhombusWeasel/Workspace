/* Workspace — splitting pane layout */

Workspace {
    height: 1fr;
    width: 1fr;
}

PaneContainer {
    border: round $surface-lighten-2;
    height: 1fr;
    width: 1fr;
    padding: 0;
}

PaneContainer.focused {
    border: round $primary;
}

/* Empty pane (last pane closed) */
PaneContainer:empty {
    border: round $surface-lighten-1;
}

/* Split containers fill their space */
#workspace > Horizontal,
#workspace > Vertical {
    height: 1fr;
    width: 1fr;
}
